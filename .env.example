# Copy this file to .env for local development. Never commit real secret values.
OPENROUTER_API_KEY=
OPENROUTER_IMAGE_MODEL=google/gemini-3.1-flash-image
# 4K image-to-image requests can take several minutes. Valid range: 30000-900000.
OPENROUTER_TIMEOUT_MS=480000

# Optional local overrides. Render supplies these through its Environment panel.
# PORT=3000
# Force the Wi-Fi/LAN adapter if automatic selection is not appropriate.
# LOCAL_IP=192.168.1.140
# PUBLIC_URL=https://your-service.onrender.com
# KIOSK_TOKEN=replace-with-a-long-random-value
# OPERATOR_TOKEN=replace-with-a-different-long-random-value
