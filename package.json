{
  "name": "phone-gyro-control",
  "version": "1.0.0",
  "description": "Holobox maze controlled from a paired smartphone gyroscope",
  "main": "server.js",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "node server.js",
    "check": "tsc --noEmit",
    "lint": "node --check server.js && node --check run.js && node --check shared/protocol.js && node --check server/eventStore.js && node --check server/networkAddress.js && node --check server/sessionCoordinator.js",
    "test": "node --test tests/*.test.js",
    "build": "vite build",
    "start": "node server.js --prod",
    "start:prod": "node server.js --prod",
    "preview:prod": "npm run build && node run.js",
    "event": "npm run preview:prod",
    "verify": "npm run lint && npm run check && npm test && npm run build"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.19.3",
    "@mediapipe/tasks-vision": "^0.10.35",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "@types/three": "^0.185.0",
    "express": "^5.2.1",
    "fflate": "^0.8.3",
    "qrcode": "^1.5.4",
    "selfsigned": "^5.5.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "three": "^0.185.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6"
  }
}
